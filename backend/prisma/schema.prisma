generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PriceHistory {
  id             Int      @id @default(autoincrement())
  date           String   @unique
  diesel_b7      Float?
  diesel_b10     Float?
  diesel_b20     Float?
  gasohol_91     Float?
  gasohol_95     Float?
  e20            Float?
  e85            Float?
  premium_diesel Float?
  brent          Float?
  source         String   @default("cached")
  updatedAt      DateTime @updatedAt
}
